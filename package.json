{
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "lint": "oxlint",
    "start": "node scripts/cli.ts",
    "prepare": "simple-git-hooks && git submodule update --init --recursive"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts}": "oxlint --fix"
  },
  "packageManager": "pnpm@10.32.1"
}
